# Copy this file to .env.local and fill in your Notion credentials.
# Without these, the site falls back to sample placeholder gigs so dev still works.

# Notion integration token (starts with "secret_" or "ntn_")
# Create at: https://www.notion.so/my-integrations
NOTION_TOKEN=

# Database IDs (the 32-char UUID from the database URL).
# Share each database with your Notion integration (Share → add integration).
NOTION_DB_GIGS=
NOTION_DB_ABOUT=
